      "pack_hebrew_desc": "\u0395\u03c0\u03b9\u03bb\u03bf\u03b3\u03ad\u03c2 \u03b1\u03c0\u03cc \u03c4\u03b7\u03bd \u03a4\u03bf\u03c1\u03ac \u03ba\u03b1\u03b9 \u03c4\u03bf\u03c5\u03c2 \u03a0\u03c1\u03bf\u03c6\u03ae\u03c4\u03b5\u03c2",
      "pack_arabic_desc": "\u0391\u03c1\u03b1\u03b2\u03b9\u03ba\u03ac \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b9\u03ba\u03ac \u03b1\u03bd\u03b1\u03b3\u03bd\u03ce\u03c3\u03bc\u03b1\u03c4\u03b1",
      "pack_greek_desc": "\u039a\u03bb\u03b1\u03c3\u03b9\u03ba\u03ac \u03ba\u03b1\u03b9 \u03b2\u03b9\u03b2\u03bb\u03b9\u03ba\u03ac \u03b5\u03bb\u03bb\u03b7\u03bd\u03b9\u03ba\u03ac \u03ba\u03b5\u03af\u03bc\u03b5\u03bd\u03b1",
      "pack_maltese_desc": "\u03a0\u03b1\u03c1\u03b1\u03b4\u03bf\u03c3\u03b9\u03b1\u03ba\u03ad\u03c2 \u03bc\u03b1\u03bb\u03c4\u03b5\u03b6\u03b9\u03ba\u03ad\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b5\u03c5\u03c7\u03ad\u03c2",
      "pack_psalter_desc": "\u039b\u03b1\u03c4\u03b9\u03bd\u03b9\u03ba\u03bf\u03af \u03a8\u03b1\u03bb\u03bc\u03bf\u03af \u03b1\u03c0\u03cc \u03c4\u03b7 \u0392\u03bf\u03c5\u03bb\u03b3\u03ac\u03c4\u03b1",
      "pack_vulgata_desc": "\u03a0\u03bb\u03ae\u03c1\u03b7\u03c2 \u039b\u03b1\u03c4\u03b9\u03bd\u03b9\u03ba\u03ae \u0392\u03af\u03b2\u03bb\u03bf\u03c2",
