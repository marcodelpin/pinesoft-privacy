    "tagline": "\u0928\u0935\u0940\u0928 \u092e\u094b\u092c\u093e\u0907\u0932 \u0910\u092a\u094d\u0938 \u0914\u0930 \u091c\u093e\u092f\u0930\u094b\u0938\u094d\u0915\u094b\u092a \u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u0917\u0947\u092e\u094d\u0938",
    "meta_description": "PineSoft \u0928\u0935\u0940\u0928 \u092e\u094b\u092c\u093e\u0907\u0932 \u0910\u092a\u094d\u0938 \u0914\u0930 \u091c\u093e\u092f\u0930\u094b\u0938\u094d\u0915\u094b\u092a \u0917\u0947\u092e\u094d\u0938 \u092c\u0928\u093e\u0924\u093e \u0939\u0948. \u0911\u0921\u093f\u092f\u094b \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923, \u0926\u0941\u0930\u094d\u0932\u092d \u092d\u093e\u0937\u093e \u0938\u0902\u0930\u0915\u094d\u0937\u0923, \u0914\u0930 20 \u0917\u0947\u092e\u094d\u0938.",
    "find_on_play": "\u0939\u092e\u0947\u0902 Google Play \u092a\u0930 \u0916\u094b\u091c\u0947\u0902",
    "games_count": "20 \u0917\u0947\u092e\u094d\u0938",
    "games_desc": "\u091c\u093e\u092f\u0930\u094b\u0938\u094d\u0915\u094b\u092a \u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u0917\u0947\u092e\u094d\u0938. \u092a\u0939\u0947\u0932\u0940, \u0915\u094c\u0936\u0932, \u0910\u0915\u094d\u0936\u0928 \u0914\u0930 \u0905\u0927\u093f\u0915.",
    "tools_count": "2 \u0910\u092a\u094d\u0938",
    "tools_desc": "\u0911\u0921\u093f\u092f\u094b \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923, \u0938\u0902\u0917\u0940\u0924 \u091f\u094d\u092f\u0942\u0928\u093f\u0902\u0917 \u0914\u0930 \u0909\u092a\u092f\u094b\u0917\u093f\u0924\u093e \u0910\u092a\u094d\u0938.",
    "reading_count": "1 \u0910\u092a",
    "reading_desc": "\u0926\u0941\u0930\u094d\u0932\u092d, \u0932\u0941\u092a\u094d\u0924\u092a\u094d\u0930\u093e\u092f \u0914\u0930 \u0936\u093e\u0938\u094d\u0924\u094d\u0930\u0940\u092f \u092d\u093e\u0937\u093e\u0913\u0902 \u0915\u093e \u0921\u093f\u091c\u093f\u091f\u0932 \u0938\u0902\u0930\u0915\u094d\u0937\u0923.",
    "about_p1": "PineSoft \u0928\u0935\u0940\u0928 \u092e\u094b\u092c\u093e\u0907\u0932 \u0910\u092a\u094d\u0938 \u0914\u0930 \u091c\u093e\u092f\u0930\u094b\u0938\u094d\u0915\u094b\u092a \u0917\u0947\u092e\u094d\u0938 \u092c\u0928\u093e\u0924\u093e \u0939\u0948. AI \u0911\u0921\u093f\u092f\u094b \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u0938\u0947 \u0926\u0941\u0930\u094d\u0932\u092d \u092d\u093e\u0937\u093e\u0913\u0902 \u0915\u0947 \u0938\u0902\u0930\u0915\u094d\u0937\u0923 \u0924\u0915, \u0914\u0930 20 \u0917\u0947\u092e\u094d\u0938 \u091c\u094b \u0906\u092a\u0915\u0947 \u092b\u094b\u0928 \u0915\u094b \u0915\u0902\u091f\u094d\u0930\u094b\u0932\u0930 \u092e\u0947\u0902 \u092c\u0926\u0932 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902.",
    "about_p2": "\u0939\u092e\u093e\u0930\u0947 \u0938\u092d\u0940 \u0909\u0924\u094d\u092a\u093e\u0926 \u092a\u0930\u093f\u0935\u093e\u0930-\u0905\u0928\u0941\u0915\u0942\u0932 \u0939\u0948\u0902, \u0935\u092f\u0938\u094d\u0915 \u0935\u093f\u091c\u094d\u091e\u093e\u092a\u0928\u094b\u0902 \u0915\u0947 \u092c\u093f\u0928\u093e, \u0914\u0930 \u0915\u0908 \u092d\u093e\u0937\u093e\u0913\u0902 \u0915\u093e \u0938\u092e\u0930\u094d\u0925\u0928 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902.",
