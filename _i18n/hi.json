      "feat_texts_title": "\u0926\u0941\u0930\u094d\u0932\u092d \u092d\u093e\u0937\u093e\u0913\u0902 \u092e\u0947\u0902 \u092a\u093e\u0920",
      "feat_texts_desc": "\u0918\u091f\u0924\u0940 \u092f\u093e \u0930\u0941\u0915\u0940 \u0939\u0941\u0908 \u0938\u0902\u092a\u093e\u0926\u0915\u0940\u092f \u0917\u0924\u093f\u0935\u093f\u0927\u093f \u0935\u093e\u0932\u0940 \u092d\u093e\u0937\u093e\u0913\u0902 \u092e\u0947\u0902 \u0932\u093f\u091f\u0930\u094d\u091c\u093f\u0915\u0932 \u0914\u0930 \u0936\u093e\u0938\u094d\u0924\u094d\u0930\u0940\u092f \u092a\u093e\u0920. \u0906\u0928\u0947 \u0935\u093e\u0932\u0940 \u092a\u0940\u0922\u093c\u093f\u092f\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0921\u093f\u091c\u093f\u091f\u0932 \u0938\u0902\u0930\u0915\u094d\u0937\u0923.",
      "feat_calendars_title": "9 \u0915\u0948\u0932\u0947\u0902\u0921\u0930 \u092a\u094d\u0930\u0923\u093e\u0932\u093f\u092f\u093e\u0901",
      "feat_calendars_desc": "\u0930\u094b\u092e\u0928, \u0915\u0949\u092a\u094d\u091f\u093f\u0915, \u092e\u094b\u091c\u093c\u093e\u0930\u0947\u092c\u093f\u0915, \u0907\u0925\u093f\u092f\u094b\u092a\u093f\u092f\u0928, \u092f\u0939\u0942\u0926\u0940, \u0907\u0938\u094d\u0932\u093e\u092e\u0940, \u0936\u0948\u0915\u094d\u0937\u093f\u0915, \u0927\u093e\u0930\u094d\u092e\u093f\u0915 \u0938\u0902\u0918\u094b\u0902 \u0914\u0930 \u0927\u0930\u094d\u092e\u092a\u094d\u0930\u093e\u0902\u0924\u0940\u092f \u0915\u0948\u0932\u0947\u0902\u0921\u0930.",
      "feat_bible_title": "\u092c\u093e\u0907\u092c\u0932 \u0905\u0928\u0941\u0935\u093e\u0926",
      "feat_bible_desc": "Vulgata Clementina (\u0932\u0948\u091f\u093f\u0928), Martini 1781 \u0914\u0930 Diodati 1607. \u0935\u093f\u0927\u093e\u0928, \u0936\u094d\u0930\u0947\u0923\u0940, \u092a\u0941\u0938\u094d\u0924\u0915 \u0914\u0930 \u0905\u0927\u094d\u092f\u093e\u092f \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930 \u0916\u094b\u091c\u0947\u0902.",
      "feat_multiscript_title": "\u092c\u0939\u0941-\u0932\u093f\u092a\u093f \u0938\u092e\u0930\u094d\u0925\u0928",
      "feat_multiscript_desc": "\u0932\u0948\u091f\u093f\u0928, \u0905\u0930\u092c\u0940, \u0939\u093f\u092c\u094d\u0930\u0942, \u0938\u0940\u0930\u093f\u092f\u093e\u0908, \u0915\u0949\u092a\u094d\u091f\u093f\u0915, \u0917\u0940\u091c\u093c, \u0917\u094d\u0930\u0940\u0915, \u0917\u0949\u0925\u093f\u0915, \u0906\u0930\u094d\u092e\u0947\u0928\u093f\u092f\u093e\u0908, \u0926\u0947\u0935\u0928\u093e\u0917\u0930\u0940 \u0914\u0930 \u0905\u0928\u094d\u092f.",
      "feat_search_title": "\u092a\u0942\u0930\u094d\u0923-\u092a\u093e\u0920 \u0916\u094b\u091c",
      "feat_search_desc": "\u0938\u092d\u0940 \u0938\u094d\u0925\u093e\u092a\u093f\u0924 \u092a\u093e\u0920\u094d\u092f\u094b\u0902 \u092e\u0947\u0902 \u0924\u0941\u0930\u0902\u0924 \u092a\u0930\u093f\u0923\u093e\u092e\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u0916\u094b\u091c\u0947\u0902. \u0915\u094b\u0908 \u092d\u0940 \u0905\u0902\u0936, \u091c\u093e\u0924 \u092f\u093e \u092a\u094d\u0930\u093e\u0930\u094d\u0925\u0928\u093e \u0916\u094b\u091c\u0947\u0902.",
      "feat_packs_title": "\u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u0948\u0915",
      "feat_packs_desc": "\u092e\u0949\u0921\u094d\u092f\u0942\u0932\u0930 \u0938\u094d\u0925\u093e\u092a\u0928\u093e \u2014 \u0915\u0947\u0935\u0932 \u0935\u0939\u0940 \u092d\u093e\u0937\u093e\u090f\u0901 \u0914\u0930 \u092a\u093e\u0920 \u0921\u093e\u0909\u0928\u0932\u094b\u0921 \u0915\u0930\u0947\u0902 \u091c\u094b \u0906\u092a\u0915\u094b \u091a\u093e\u0939\u093f\u090f. \u0939\u0932\u094d\u0915\u093e \u0914\u0930 \u0915\u0941\u0936\u0932.",
      "feat_dark_title": "\u0921\u093e\u0930\u094d\u0915 \u0925\u0940\u092e",
      "feat_dark_desc": "\u091a\u093f\u0902\u0924\u0928\u0936\u0940\u0932 \u092a\u0920\u0928 \u0915\u0947 \u0932\u093f\u090f \u0921\u093f\u091c\u093c\u093e\u0907\u0928 \u0915\u093f\u092f\u093e \u0917\u092f\u093e. \u0926\u093f\u0928 \u0914\u0930 \u0930\u093e\u0924 \u0906\u0901\u0916\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0906\u0930\u093e\u092e\u0926\u093e\u092f\u0915.",
      "feat_private_title": "\u0928\u093f\u091c\u0940 \u0914\u0930 \u0911\u092b\u0932\u093e\u0907\u0928",
      "feat_private_desc": "\u0915\u094b\u0908 \u0916\u093e\u0924\u093e \u0928\u0939\u0940\u0902, \u0915\u094b\u0908 \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917 \u0928\u0939\u0940\u0902, \u0915\u094b\u0908 \u0935\u093f\u091c\u094d\u091e\u093e\u092a\u0928 \u0928\u0939\u0940\u0902. \u0938\u092d\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0906\u092a\u0915\u0947 \u0921\u093f\u0935\u093e\u0907\u0938 \u092a\u0930 \u0938\u094d\u0925\u093e\u0928\u0940\u092f \u0930\u0942\u092a \u0938\u0947 \u0938\u0902\u0938\u093e\u0927\u093f\u0924 \u0914\u0930 \u0938\u0902\u0917\u094d\u0930\u0939\u0940\u0924 \u0939\u094b\u0924\u0940 \u0939\u0948.",
      "scripts_supported": "\u0938\u092e\u0930\u094d\u0925\u093f\u0924",
      "scripts_word": "\u0932\u093f\u092a\u093f\u092f\u093e\u0901",
      "scripts_intro": "\u092c\u0902\u0921\u0932\u0947\u0921 Noto Sans \u092b\u093c\u0949\u0928\u094d\u091f\u094d\u0938 \u0915\u0947 \u0938\u093e\u0925 \u092e\u0942\u0932 \u0932\u093f\u092a\u093f \u092a\u094d\u0930\u0923\u093e\u0932\u093f\u092f\u094b\u0902 \u092e\u0947\u0902 \u092a\u093e\u0920 \u092a\u0922\u093c\u0947\u0902.",
      "languages_modern": "\u0932\u0948\u091f\u093f\u0928, \u0907\u0924\u093e\u0932\u0935\u0940, \u091c\u0949\u0930\u094d\u091c\u093f\u092f\u0928, \u0905\u0930\u092c\u0940, \u0915\u0949\u092a\u094d\u091f\u093f\u0915, \u0938\u0940\u0930\u093f\u092f\u093e\u0908, \u0939\u093f\u092c\u094d\u0930\u0942, \u0917\u094d\u0930\u0940\u0915, \u092e\u093e\u0932\u094d\u091f\u0940\u091c\u093c \u0906\u0926\u093f \u092d\u093e\u0937\u093e\u0913\u0902 \u092e\u0947\u0902 \u092a\u093e\u0920 \u0909\u092a\u0932\u092c\u094d\u0927 \u0939\u0948\u0902.",
      "packs_available": "\u0909\u092a\u0932\u092c\u094d\u0927",
      "packs_word": "\u092a\u0948\u0915",
      "packs_intro": "\u0915\u0947\u0935\u0932 \u0935\u0939\u0940 \u092d\u093e\u0937\u093e\u090f\u0901 \u0914\u0930 \u092a\u093e\u0920 \u0907\u0902\u0938\u094d\u091f\u0949\u0932 \u0915\u0930\u0947\u0902 \u091c\u094b \u0906\u092a\u0915\u094b \u091a\u093e\u0939\u093f\u090f. \u0938\u092d\u0940 \u092a\u0948\u0915 \u0928\u093f\u0903\u0936\u0941\u0932\u094d\u0915 \u0939\u0948\u0902 \u0914\u0930 \u092a\u0942\u0930\u0940 \u0924\u0930\u0939 \u0911\u092b\u0932\u093e\u0907\u0928 \u0915\u093e\u092e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902.",
