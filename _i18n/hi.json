      "pack_martini_desc": "\u0915\u0948\u0925\u094b\u0932\u093f\u0915 \u0907\u0924\u093e\u0932\u0935\u0940 \u092c\u093e\u0907\u092c\u0932 (1781)",
      "pack_diodati_desc": "\u092a\u094d\u0930\u094b\u091f\u0947\u0938\u094d\u091f\u0947\u0902\u091f \u0907\u0924\u093e\u0932\u0935\u0940 \u092c\u093e\u0907\u092c\u0932 (1607)",
      "privacy_your": "\u0906\u092a\u0915\u0940",
      "privacy_word": "\u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e",
      "privacy_text": "Horatio \u092a\u0942\u0930\u0940 \u0924\u0930\u0939 \u0911\u092b\u0932\u093e\u0907\u0928 \u0939\u0948. \u0915\u094b\u0908 \u0921\u0947\u091f\u093e \u0928\u0939\u0940\u0902 \u090f\u0915\u0924\u094d\u0930 \u0915\u093f\u092f\u093e, \u092a\u094d\u0930\u0947\u0937\u093f\u0924 \u092f\u093e \u0938\u093e\u091d\u093e \u0915\u093f\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948. \u0916\u093e\u0924\u093e \u0906\u0935\u0936\u094d\u092f\u0915 \u0928\u0939\u0940\u0902, \u0935\u093f\u091c\u094d\u091e\u093e\u092a\u0928 \u0928\u0939\u0940\u0902, \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917 \u0928\u0939\u0940\u0902.",
      "privacy_link": "\u092a\u0942\u0930\u094d\u0923 \u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0928\u0940\u0924\u093f"
