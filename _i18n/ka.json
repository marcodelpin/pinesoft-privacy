      "feat_private_title": "\u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10d8 \u10d3\u10d0 \u10dd\u10e4\u10da\u10d0\u10d8\u10dc",
      "feat_private_desc": "\u10d0\u10dc\u10d2\u10d0\u10e0\u10d8\u10e8\u10d8\u10e1, \u10d7\u10d5\u10d0\u10da\u10d7\u10d5\u10d0\u10da\u10d8\u10e1 \u10d0\u10dc \u10e0\u10d4\u10d9\u10da\u10d0\u10db\u10d8\u10e1 \u10d2\u10d0\u10e0\u10d4\u10e8\u10d4. \u10e7\u10d5\u10d4\u10da\u10d0 \u10e8\u10d8\u10d2\u10d7\u10d0\u10d5\u10e1\u10d8 \u10da\u10dd\u10d9\u10d0\u10da\u10e3\u10e0\u10d0\u10d3 \u10db\u10e3\u10e8\u10d0\u10d5\u10d3\u10d4\u10d1\u10d0 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 \u10db\u10dd\u10ec\u10e7\u10dd\u10d1\u10d8\u10da\u10dd\u10d1\u10d0\u10d6\u10d4.",
      "scripts_supported": "\u10db\u10ee\u10d0\u10e0\u10d3\u10d0\u10ed\u10d4\u10e0\u10d8\u10da\u10d8",
      "scripts_word": "\u10d3\u10d0\u10db\u10ec\u10d4\u10e0\u10da\u10dd\u10d1\u10d4\u10d1\u10d8",
      "scripts_intro": "\u10ec\u10d0\u10d8\u10d9\u10d8\u10d7\u10ee\u10d4\u10d7 \u10e2\u10d4\u10e5\u10e1\u10e2\u10d4\u10d1\u10d8 \u10db\u10d0\u10d7\u10d8 \u10dd\u10e0\u10d8\u10d2\u10d8\u10dc\u10d0\u10da\u10e3\u10e0\u10d8 \u10d3\u10d0\u10db\u10ec\u10d4\u10e0\u10da\u10dd\u10d1\u10d8\u10e1 \u10e1\u10d8\u10e1\u10e2\u10d4\u10db\u10d4\u10d1\u10e8\u10d8 Noto Sans \u10e8\u10e0\u10d8\u10e4\u10e2\u10d4\u10d1\u10d8\u10d7.",
      "languages_modern": "\u10e2\u10d4\u10e5\u10e1\u10e2\u10d4\u10d1\u10d8 \u10ee\u10d4\u10da\u10db\u10d8\u10e1\u10d0\u10ec\u10d5\u10d3\u10dd\u10db\u10d8\u10d0: \u10da\u10d0\u10d7\u10d8\u10dc\u10e3\u10e0\u10d8, \u10d8\u10e2\u10d0\u10da\u10d8\u10e3\u10e0\u10d8, \u10e5\u10d0\u10e0\u10d7\u10e3\u10da\u10d8, \u10d0\u10e0\u10d0\u10d1\u10e3\u10da\u10d8, \u10d9\u10dd\u10de\u10e2\u10e3\u10e0\u10d8, \u10e1\u10d8\u10e0\u10d8\u10e3\u10da\u10d8, \u10d4\u10d1\u10e0\u10d0\u10e3\u10da\u10d8, \u10d1\u10d4\u10e0\u10eb\u10dc\u10e3\u10da\u10d8, \u10db\u10d0\u10da\u10e2\u10e3\u10e0\u10d8 \u10d3\u10d0 \u10e1\u10ee\u10d5\u10d0.",
      "packs_available": "\u10ee\u10d4\u10da\u10db\u10d8\u10e1\u10d0\u10ec\u10d5\u10d3\u10dd\u10db\u10d8",
      "packs_word": "\u10de\u10d0\u10d9\u10d4\u10e2\u10d4\u10d1\u10d8",
      "packs_intro": "\u10d3\u10d0\u10d0\u10d8\u10dc\u10e1\u10e2\u10d0\u10da\u10d8\u10e0\u10d4\u10d7 \u10db\u10ee\u10dd\u10da\u10dd\u10d3 \u10e1\u10d0\u10ed\u10d8\u10e0\u10dd \u10d4\u10dc\u10d4\u10d1\u10d4\u10d1\u10d8 \u10d3\u10d0 \u10e2\u10d4\u10e5\u10e1\u10e2\u10d4\u10d1\u10d8. \u10e7\u10d5\u10d4\u10da\u10d0 \u10de\u10d0\u10d9\u10d4\u10e2\u10d8 \u10e3\u10e4\u10d0\u10e1\u10dd\u10d0 \u10d3\u10d0 \u10e1\u10e0\u10e3\u10da\u10d0\u10d3 \u10dd\u10e4\u10da\u10d0\u10d8\u10dc \u10db\u10e3\u10e8\u10d0\u10dd\u10d1\u10e1.",
      "packs_bundled": "\u10e9\u10d0\u10e8\u10d4\u10dc\u10d4\u10d1\u10e3\u10da\u10d8",
      "packs_in_app": "\u10d0\u10de\u10da\u10d8\u10d9\u10d0\u10ea\u10d8\u10d0\u10e8\u10d8",
      "packs_note": "\u10d3\u10d0\u10d0\u10d7\u10d5\u10d0\u10da\u10d8\u10d4\u10e0\u10d4\u10d7 \u10d3\u10d0 \u10d3\u10d0\u10d0\u10d8\u10dc\u10e1\u10e2\u10d0\u10da\u10d8\u10e0\u10d4\u10d7 \u10de\u10d0\u10d9\u10d4\u10e2\u10d4\u10d1\u10d8 \u10d0\u10de\u10da\u10d8\u10d9\u10d0\u10ea\u10d8\u10d8\u10e1 \u10de\u10d0\u10d9\u10d4\u10e2\u10d4\u10d1\u10d8\u10e1 \u10db\u10d4\u10dc\u10d4\u10ef\u10d4\u10e0\u10d8\u10d3\u10d0\u10dc.",
      "packs_more": "\u10db\u10d4\u10e2\u10d8 \u10d4\u10dc\u10dd\u10d1\u10e0\u10d8\u10d5\u10d8 \u10de\u10d0\u10d9\u10d4\u10e2\u10d4\u10d1\u10d8 \u10db\u10d0\u10da\u10d4 \u10db\u10dd\u10d5\u10d0",
      "packs_create_link": "\u10e8\u10d4\u10e5\u10db\u10d4\u10dc\u10d8\u10d7 \u10e1\u10d0\u10d9\u10e3\u10d7\u10d0\u10e0\u10d8 \u10de\u10d0\u10d9\u10d4\u10e2\u10d8 \u2192",
      "pack_georgian_desc": "\u10e1\u10d0\u10d0\u10d7\u10d7\u10d0 \u10da\u10d8\u10e2\u10e3\u10e0\u10d2\u10d8\u10d0 \u10e5\u10d0\u10e0\u10d7\u10e3\u10da \u10d3\u10d0\u10db\u10ec\u10d4\u10e0\u10da\u10dd\u10d1\u10d0\u10e8\u10d8",
      "pack_coptic_desc": "\u10db\u10d0\u10e0\u10d9\u10dd\u10d6\u10d8\u10e1 \u10e1\u10d0\u10ee\u10d0\u10e0\u10d4\u10d1\u10d0 \u10d9\u10dd\u10de\u10e2\u10e3\u10e0\u10d0\u10d3",
      "pack_syriac_desc": "\u10de\u10d4\u10e8\u10d8\u10e2\u10d0\u10e1 \u10da\u10d8\u10e2\u10e3\u10e0\u10d2\u10d8\u10d9\u10e3\u10da\u10d8 \u10d9\u10dd\u10e0\u10de\u10e3\u10e1\u10d8",
      "pack_hebrew_desc": "\u10d7\u10dd\u10e0\u10d0\u10e1 \u10d3\u10d0 \u10ec\u10d8\u10dc\u10d0\u10e1\u10ec\u10d0\u10e0\u10db\u10d4\u10e2\u10e7\u10d5\u10d4\u10da\u10d4\u10d1\u10d8\u10e1 \u10dc\u10d0\u10ec\u10e7\u10d5\u10d4\u10e2\u10d4\u10d1\u10d8",
      "pack_arabic_desc": "\u10d0\u10e0\u10d0\u10d1\u10e3\u10da\u10d8 \u10da\u10d8\u10e2\u10e3\u10e0\u10d2\u10d8\u10d9\u10e3\u10da\u10d8 \u10e1\u10d0\u10d9\u10d8\u10d7\u10ee\u10d0\u10d5\u10d4\u10d1\u10d8",
      "pack_greek_desc": "\u10d9\u10da\u10d0\u10e1\u10d8\u10d9\u10e3\u10e0\u10d8 \u10d3\u10d0 \u10d1\u10d8\u10d1\u10da\u10d8\u10e3\u10e0\u10d8 \u10d1\u10d4\u10e0\u10eb\u10dc\u10e3\u10da\u10d8 \u10e2\u10d4\u10e5\u10e1\u10e2\u10d4\u10d1\u10d8",
      "pack_maltese_desc": "\u10e2\u10e0\u10d0\u10d3\u10d8\u10ea\u10d8\u10e3\u10da\u10d8 \u10db\u10d0\u10da\u10e2\u10e3\u10e0\u10d8 \u10da\u10dd\u10ea\u10d5\u10d4\u10d1\u10d8",
      "pack_psalter_desc": "\u10da\u10d0\u10d7\u10d8\u10dc\u10e3\u10e0\u10d8 \u10e4\u10e1\u10d0\u10da\u10db\u10e3\u10dc\u10d4\u10d1\u10d8 \u10d5\u10e3\u10da\u10d2\u10d0\u10e2\u10d0\u10d3\u10d0\u10dc",
      "pack_vulgata_desc": "\u10e1\u10e0\u10e3\u10da\u10d8 \u10da\u10d0\u10d7\u10d8\u10dc\u10e3\u10e0\u10d8 \u10d1\u10d8\u10d1\u10da\u10d8\u10d0",
      "pack_martini_desc": "\u10d9\u10d0\u10d7\u10dd\u10da\u10d8\u10d9\u10e3\u10e0\u10d8 \u10d8\u10e2\u10d0\u10da\u10d8\u10e3\u10e0\u10d8 \u10d1\u10d8\u10d1\u10da\u10d8\u10d0 (1781)",
      "pack_diodati_desc": "\u10de\u10e0\u10dd\u10e2\u10d4\u10e1\u10e2\u10d0\u10dc\u10e2\u10e3\u10da\u10d8 \u10d8\u10e2\u10d0\u10da\u10d8\u10e3\u10e0\u10d8 \u10d1\u10d8\u10d1\u10da\u10d8\u10d0 (1607)",
      "privacy_your": "\u10d7\u10e5\u10d5\u10d4\u10dc\u10d8",
      "privacy_word": "\u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d0",
      "privacy_text": "Horatio \u10e1\u10e0\u10e3\u10da\u10d0\u10d3 \u10dd\u10e4\u10da\u10d0\u10d8\u10dc \u10db\u10e3\u10e8\u10d0\u10dd\u10d1\u10e1. \u10d0\u10e0\u10d0\u10dc\u10d0\u10d8\u10e0\u10d8 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d8 \u10d0\u10e0 \u10d2\u10e0\u10dd\u10d5\u10d3\u10d4\u10d1\u10d0, \u10d0\u10e0 \u10d2\u10d0\u10d3\u10d0\u10d8\u10ea\u10d4\u10db\u10d0 \u10d0\u10dc \u10d2\u10d0\u10d6\u10d8\u10d0\u10e0\u10d3\u10d4\u10d1\u10d0. \u10d0\u10dc\u10d2\u10d0\u10e0\u10d8\u10e8\u10d8\u10e1, \u10e0\u10d4\u10d9\u10da\u10d0\u10db\u10d8\u10e1 \u10d0\u10dc \u10d7\u10d5\u10d0\u10da\u10d7\u10d5\u10d0\u10da\u10d8\u10e1 \u10d2\u10d0\u10e0\u10d4\u10e8\u10d4.",
      "privacy_link": "\u10e1\u10e0\u10e3\u10da\u10d8 \u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d8\u10e1 \u10de\u10dd\u10da\u10d8\u10e2\u10d8\u10d9\u10d0"
    }
  }
