      "feat_calendars_desc": "\u10e0\u10dd\u10db\u10d0\u10e3\u10da\u10d8, \u10d9\u10dd\u10de\u10e2\u10e3\u10e0\u10d8, \u10db\u10dd\u10d6\u10d0\u10e0\u10d0\u10d1\u10e3\u10da\u10d8, \u10d4\u10d7\u10d8\u10dd\u10de\u10e3\u10e0\u10d8, \u10d8\u10e3\u10d3\u10d4\u10e3\u10e0\u10d8, \u10d8\u10e1\u10da\u10d0\u10db\u10e3\u10e0\u10d8, \u10d0\u10d9\u10d0\u10d3\u10d4\u10db\u10d8\u10e3\u10e0\u10d8, \u10e1\u10d0\u10db\u10dd\u10dc\u10d0\u10e1\u10e2\u10e0\u10dd \u10d3\u10d0 \u10d4\u10de\u10d0\u10e0\u10e5\u10d8\u10d0\u10da\u10e3\u10e0\u10d8 \u10d9\u10d0\u10da\u10d4\u10dc\u10d3\u10e0\u10d4\u10d1\u10d8.",
      "feat_bible_title": "\u10d1\u10d8\u10d1\u10da\u10d8\u10d8\u10e1 \u10d7\u10d0\u10e0\u10d2\u10db\u10d0\u10dc\u10d4\u10d1\u10d8",
      "feat_bible_desc": "Vulgata Clementina (\u10da\u10d0\u10d7\u10d8\u10dc\u10e3\u10e0\u10d8), Martini 1781 \u10d3\u10d0 Diodati 1607. \u10d3\u10d0\u10d7\u10d5\u10d0\u10da\u10d8\u10d4\u10e0\u10d4\u10d7 \u10d0\u10e6\u10d7\u10e5\u10db\u10d8\u10e1, \u10d9\u10d0\u10e2\u10d4\u10d2\u10dd\u10e0\u10d8\u10d8\u10e1, \u10ec\u10d8\u10d2\u10dc\u10d8\u10e1 \u10d3\u10d0 \u10d7\u10d0\u10d5\u10d8\u10e1 \u10db\u10d8\u10ee\u10d4\u10d3\u10d5\u10d8\u10d7.",
      "feat_multiscript_title": "\u10db\u10e0\u10d0\u10d5\u10d0\u10da\u10d8 \u10d3\u10d0\u10db\u10ec\u10d4\u10e0\u10da\u10dd\u10d1\u10d8\u10e1 \u10db\u10ee\u10d0\u10e0\u10d3\u10d0\u10ed\u10d4\u10e0\u10d0",
      "feat_multiscript_desc": "\u10da\u10d0\u10d7\u10d8\u10dc\u10e3\u10e0\u10d8, \u10d0\u10e0\u10d0\u10d1\u10e3\u10da\u10d8, \u10d4\u10d1\u10e0\u10d0\u10e3\u10da\u10d8, \u10e1\u10d8\u10e0\u10d8\u10e3\u10da\u10d8, \u10d9\u10dd\u10de\u10e2\u10e3\u10e0\u10d8, \u10d2\u10d4\u10d4\u10d6, \u10d1\u10d4\u10e0\u10eb\u10dc\u10e3\u10da\u10d8, \u10d2\u10dd\u10d7\u10e3\u10e0\u10d8, \u10e1\u10dd\u10db\u10ee\u10e3\u10e0\u10d8, \u10d3\u10d4\u10d5\u10d0\u10dc\u10d0\u10d2\u10d0\u10e0\u10d8 \u10d3\u10d0 \u10e1\u10ee\u10d5\u10d0.",
      "feat_search_title": "\u10e1\u10e0\u10e3\u10da\u10d8 \u10e2\u10d4\u10e5\u10e1\u10e2\u10d8\u10e1 \u10eb\u10d8\u10d4\u10d1\u10d0",
      "feat_search_desc": "\u10db\u10dd\u10d8\u10eb\u10d8\u10d4\u10d7 \u10e7\u10d5\u10d4\u10da\u10d0 \u10d3\u10d0\u10d8\u10dc\u10e1\u10e2\u10d0\u10da\u10d8\u10e0\u10d4\u10d1\u10e3\u10da \u10e2\u10d4\u10e5\u10e1\u10e2\u10e8\u10d8 \u10db\u10e7\u10d8\u10e1\u10d8\u10d4\u10e0\u10d8 \u10e8\u10d4\u10d3\u10d4\u10d2\u10d4\u10d1\u10d8\u10d7.",
      "feat_packs_title": "\u10e8\u10d8\u10d2\u10d7\u10d0\u10d5\u10e1\u10d8\u10e1 \u10de\u10d0\u10d9\u10d4\u10e2\u10d4\u10d1\u10d8",
